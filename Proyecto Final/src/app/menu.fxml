<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.Color?>

<VBox alignment="CENTER" spacing="40.0" 
      prefHeight="600.0" prefWidth="800.0" 
      style="-fx-background-color: radial-gradient(center 50% 50%, radius 100%, #101820, #000000);" 
      xmlns="http://javafx.com/javafx/25" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="app.MenuController">

   <children>
      <Label text="SPACE INVADERS" textFill="WHITE">
         <font>
            <Font name="Impact" size="80.0" />
         </font>
         <effect>
            <DropShadow radius="8.0" spread="0.2">
               <color>
                  <Color red="0.3" green="0.6" blue="1.0" /> </color>
            </DropShadow>
         </effect>
      </Label>

      <VBox alignment="CENTER" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#jugar" prefWidth="280.0" 
                    style="-fx-background-color: transparent; -fx-border-color: #00ff88; -fx-border-width: 2; -fx-text-fill: #00ff88; -fx-font-size: 22; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-radius: 8;" 
                    text="INICIAR MISIÓN" />

            <Button mnemonicParsing="false" onAction="#salir" prefWidth="280.0" 
                    style="-fx-background-color: transparent; -fx-border-color: #ff4444; -fx-border-width: 2; -fx-text-fill: #ff4444; -fx-font-size: 22; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-radius: 8;" 
                    text="ABANDONAR" />
         </children>
      </VBox>

      <Label text="Josmery Bueno - 2026" textFill="#555555">
         <font>
            <Font name="Monospaced Regular" size="13.0" />
         </font>
      </Label>
   </children>
</VBox>